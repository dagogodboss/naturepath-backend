{
  "name": "@natural-path/sdk",
  "version": "1.0.0",
  "description": "React TypeScript SDK for The Natural Path Spa Management System",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "@tanstack/react-query": ">=5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.17.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "react",
    "spa",
    "booking",
    "natural-path",
    "sdk",
    "react-query",
    "typescript"
  ],
  "author": "The Natural Path",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/natural-path/sdk"
  },
  "bugs": {
    "url": "https://github.com/natural-path/sdk/issues"
  },
  "homepage": "https://github.com/natural-path/sdk#readme"
}
